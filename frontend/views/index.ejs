<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Todo App - Frontend</title>
    <style>
        body { font-family: Arial, sans-serif; background: #f4f4f4; }
        .container { max-width: 400px; margin: 40px auto; background: #fff; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); text-align: center; }
        h1 { margin-bottom: 1.5rem; }
        a { display: inline-block; margin-top: 1rem; padding: 0.7rem 1.5rem; background: #667eea; color: #fff; border-radius: 4px; text-decoration: none; font-weight: bold; }
        a:hover { background: #556cd6; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Todo App</h1>
        <% if (todos && todos.length) { %>
            <ul style="text-align:left; margin-top:1rem;">
                <% todos.forEach(todo => { %>
                    <li>
                        <strong><%= todo.title %></strong>: <%= todo.description %>
                        <form method="POST" action="/delete" style="display:inline; margin-left:1rem;">
                            <input type="hidden" name="id" value="<%= todo._id %>">
                            <button type="submit" style="background:#c33;color:#fff;border:none;padding:0.3rem 0.6rem;border-radius:3px;cursor:pointer;">Delete</button>
                        </form>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p>No todos yet.</p>
        <% } %>
        <a href="/form">Add New Todo</a>
    </div>
</body>
</html>
